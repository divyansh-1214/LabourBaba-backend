generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Worker {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String?            @db.VarChar
  phone                String?            @unique @db.VarChar
  profile_picture_url  String?            @db.VarChar
  aadhaar_last4        String?            @db.VarChar
  verification_status  String?            @db.VarChar
  worker_score         Float?
  worker_rating        Float?
  total_jobs_completed Int?
  years_of_experience  Int?
  is_online            Boolean?
  last_seen            DateTime?          @db.Timestamp(6)
  device_id            String?            @db.VarChar
  device_token         String?            @db.VarChar
  ip_address           String?            @db.VarChar
  decline_count        Int?
  timeout_count        Int?
  skill_category_id    String?            @db.Uuid
  password             String             @db.VarChar(255)
  email                String             @unique(map: "worker_email_unique") @db.VarChar(255)
  city                 String?            @db.VarChar(255)
  booking              booking[]
  job_application      job_application[]
  job_dispatch         job_dispatch[]
  notification         notification[]
  review               review[]
  skill_category       skill_category?    @relation(fields: [skill_category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  worker_analytics     worker_analytics[]
  worker_device        worker_device[]
  worker_document      worker_document[]
  worker_location      worker_location[]

  @@map("worker")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model booking {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  job_id       String?        @db.Uuid
  worker_id    String?        @db.Uuid
  customer_id  String?        @db.Uuid
  start_time   DateTime?      @db.Timestamp(6)
  status       String?        @db.VarChar
  otp_hash     String?        @db.VarChar
  otp_verified Boolean?
  customer     customer?      @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  job          job?           @relation(fields: [job_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_booking_job")
  worker       Worker?        @relation(fields: [worker_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_booking_worker")
  conversation conversation[]
  payment      payment[]
  review       review[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model job {
  id                    String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id           String?           @db.Uuid
  category_id           String?           @db.Uuid
  description           String?
  latitude              Float?
  longitude             Float?
  location              String?
  budget                Int?
  status                String?           @db.VarChar
  dispatch_status       String?           @db.VarChar
  current_dispatch_rank Int?
  created_at            DateTime?         @db.Timestamp(6)
  deleted_at            DateTime?         @db.Timestamp(6)
  booking               booking[]
  category              skill_category?   @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_job_category")
  customer              customer?         @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  job_application       job_application[]
  job_dispatch          job_dispatch[]
  notification          notification[]
}

model payment {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id        String?   @db.Uuid
  amount            Int?
  status            String?   @db.VarChar
  razorpay_order_id String?   @db.VarChar
  created_at        DateTime? @db.Timestamp(6)
  booking           booking?  @relation(fields: [booking_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_payment_booking")
}

model review {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id  String?   @db.Uuid
  worker_id   String?   @db.Uuid
  customer_id String?   @db.Uuid
  rating      Float?
  comment     String?
  created_at  DateTime? @db.Timestamp(6)
  booking     booking?  @relation(fields: [booking_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_review_booking")
  customer    customer? @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  worker      Worker?   @relation(fields: [worker_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model conversation {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id  String?   @db.Uuid
  worker_id   String?   @db.Uuid
  customer_id String?   @db.Uuid
  created_at  DateTime? @db.Timestamp(6)
  booking     booking?  @relation(fields: [booking_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  message     message[]
}

model customer {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String?   @db.VarChar
  phone      String?   @unique @db.VarChar
  email      String?   @db.VarChar
  city       String?   @db.VarChar
  created_at DateTime? @db.Timestamp(6)
  password   String    @db.VarChar(255)
  booking    booking[]
  job        job[]
  review     review[]
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model job_application {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  job_id            String? @db.Uuid
  worker_id         String? @db.Uuid
  status            String? @db.VarChar
  distance_km       Float?
  application_score Float?
  job               job?    @relation(fields: [job_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  worker            Worker? @relation(fields: [worker_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model job_dispatch {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  job_id       String?   @db.Uuid
  worker_id    String?   @db.Uuid
  rank         Int?
  status       String?   @db.VarChar
  notified_at  DateTime? @db.Timestamp(6)
  responded_at DateTime? @db.Timestamp(6)
  expires_at   DateTime? @db.Timestamp(6)
  job          job?      @relation(fields: [job_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  worker       Worker?   @relation(fields: [worker_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model message {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String?       @db.Uuid
  sender_id       String?       @db.Uuid
  content         String?
  created_at      DateTime?     @db.Timestamp(6)
  conversation    conversation? @relation(fields: [conversation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model notification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  worker_id  String?   @db.Uuid
  job_id     String?   @db.Uuid
  type       String?   @db.VarChar
  is_read    Boolean?
  created_at DateTime? @db.Timestamp(6)
  job        job?      @relation(fields: [job_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  worker     Worker?   @relation(fields: [worker_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model skill_category {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String?  @db.VarChar
  icon_url String?  @db.VarChar
  job      job[]
  worker   Worker[]
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model worker_analytics {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  worker_id           String?   @db.Uuid
  avg_response_time_s Float?
  acceptance_rate     Float?
  completion_rate     Float?
  calculated_at       DateTime? @db.Timestamp(6)
  worker              Worker?   @relation(fields: [worker_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model worker_device {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  worker_id  String?   @db.Uuid
  device_id  String?   @db.VarChar
  ip_address String?   @db.VarChar
  first_seen DateTime? @db.Timestamp(6)
  last_seen  DateTime? @db.Timestamp(6)
  worker     Worker?   @relation(fields: [worker_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model worker_document {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  worker_id     String? @db.Uuid
  document_type String? @db.VarChar
  file_url      String? @db.VarChar
  status        String? @db.VarChar
  worker        Worker? @relation(fields: [worker_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model worker_location {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  worker_id  String?   @db.Uuid
  latitude   Float?
  longitude  Float?
  location   String?
  updated_at DateTime? @db.Timestamp(6)
  worker     Worker?   @relation(fields: [worker_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
