generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Worker {
  worker_id     Int      @id @default(autoincrement())
  name          String   @db.VarChar(100)
  ph_number     String   @unique @db.VarChar(15)
  aadhaar_last4 String?  @db.Char(4)
  location      String?  @db.VarChar(200)
  latitude      Decimal? @db.Decimal(9, 6)
  longitude     Decimal? @db.Decimal(9, 6)
  skill         String?  @db.VarChar(100)
  rating        Decimal? @default(0.0) @db.Decimal(3, 2)
  daily_rate    Decimal? @db.Decimal(10, 2)
  is_verified   Boolean? @default(false)
  created_at    DateTime @default(now()) @db.Timestamp(6)

  @@map("worker")
}

model client {
  client_id     Int       @id @default(autoincrement())
  name          String    @db.VarChar(100)
  ph_number     String    @unique @db.VarChar(15)
  aadhaar_last4 String    @unique @db.VarChar(16)
  address       String?   @db.VarChar(100)
  city          String?   @db.VarChar(100)
  state         String?   @db.VarChar(100)
  pincode       String?   @db.VarChar(6)
  is_verified   Boolean?  @default(false)
  created_at    DateTime? @default(now()) @db.Timestamp(6)

  @@map("client")
}
