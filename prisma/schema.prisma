generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Worker {
  worker_id     Int            @id @default(autoincrement())
  name          String         @db.VarChar(100)
  ph_number     String         @unique @db.VarChar(15)
  aadhaar_last4 String?        @db.Char(4)
  location      String?        @db.VarChar(200)
  latitude      Decimal?       @db.Decimal(9, 6)
  longitude     Decimal?       @db.Decimal(9, 6)
  skill         String?        @db.VarChar(100)
  rating        Decimal?       @default(0.0) @db.Decimal(3, 2)
  daily_rate    Decimal?       @db.Decimal(10, 2)
  is_verified   Boolean?       @default(false)
  created_at    DateTime       @default(now()) @db.Timestamp(6)
  booking       booking[]
  prev_work     prev_work[]
  worker_skill  worker_skill[]

  @@map("worker")
}

model client {
  client_id     Int       @id @default(autoincrement())
  name          String    @db.VarChar(100)
  ph_number     String    @unique @db.VarChar(15)
  aadhaar_last4 String    @unique @db.VarChar(16)
  address       String?   @db.VarChar(100)
  city          String?   @db.VarChar(100)
  state         String?   @db.VarChar(100)
  pincode       String?   @db.VarChar(6)
  is_verified   Boolean?  @default(false)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  booking       booking[]
  job           job[]

  @@map("client")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model booking {
  booking_id   Int             @id @default(autoincrement())
  job_id       Int
  worker_id    Int
  client_id    Int
  status       booking_status? @default(pending)
  booked_at    DateTime?       @default(now()) @db.Timestamp(6)
  completed_at DateTime?       @db.Timestamp(6)
  client       client          @relation(fields: [client_id], references: [client_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_booking_client")
  job          job             @relation(fields: [job_id], references: [job_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_booking_job")
  worker       Worker          @relation(fields: [worker_id], references: [worker_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_booking_worker")
  payment      payment?
  review       review[]
}

model category {
  category_id Int     @id @default(autoincrement())
  name        String  @unique @db.VarChar(100)
  icon        String? @db.VarChar(100)
  job         job[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model job {
  job_id      Int       @id @default(autoincrement())
  posted_by   Int
  category_id Int?
  type        String    @db.VarChar(100)
  description String?
  max_budget  Decimal?  @db.Decimal(10, 2)
  status      String?   @default("open") @db.VarChar(20)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  booking     booking[]
  category    category? @relation(fields: [category_id], references: [category_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_job_category")
  client      client    @relation(fields: [posted_by], references: [client_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_job_client")
}

model payment {
  payment_id   Int       @id @default(autoincrement())
  booking_id   Int       @unique
  amount       Decimal   @db.Decimal(10, 2)
  platform_fee Decimal?  @default(0) @db.Decimal(10, 2)
  method       String?   @db.VarChar(50)
  txn_id       String?   @unique @db.VarChar(200)
  status       String?   @default("pending") @db.VarChar(20)
  paid_at      DateTime? @db.Timestamp(6)
  booking      booking   @relation(fields: [booking_id], references: [booking_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_payment_booking")
}

model prev_work {
  prev_work_id   Int       @id @default(autoincrement())
  worker_id      Int
  title          String?   @db.VarChar(200)
  description    String?
  image_url      String?
  date_completed DateTime? @db.Date
  worker         Worker    @relation(fields: [worker_id], references: [worker_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_prev_work_worker")
}

model review {
  review_id     Int       @id @default(autoincrement())
  booking_id    Int
  reviewer_id   Int
  reviewee_id   Int
  reviewer_type String?   @db.VarChar(10)
  rating        Int?      @db.SmallInt
  comment       String?
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  booking       booking   @relation(fields: [booking_id], references: [booking_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_review_booking")

  @@unique([booking_id, reviewer_id], map: "review_booking_id_reviewer_id_idx")
}

model skill {
  skill_id     Int            @id @default(autoincrement())
  skill_name   String?        @unique @db.VarChar(100)
  worker_skill worker_skill[]
}

model worker_skill {
  worker_id Int
  skill_id  Int
  skill     skill  @relation(fields: [skill_id], references: [skill_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_worker_skill_skill")
  worker    Worker @relation(fields: [worker_id], references: [worker_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_worker_skill_worker")

  @@id([worker_id, skill_id])
}

enum booking_status {
  pending
  accepted
  completed
  cancelled
}
